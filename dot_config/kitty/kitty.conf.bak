# font_family  MapleMono-NF-CN-Medium

#仅对中文 Unicode 范围使用霞鹜文楷
# symbol_map U+4E00-U+9FFF LXGW-WenKai-Mono
# symbol_map U+3400-U+4DBF LXGW-WenKai-Mono
# symbol_map U+F900-U+FAFF LXGW-WenKai-Mono
# symbol_map U+20000-U+2A6DF LXGW-WenKai-Mono

# BEGIN_KITTY_FONTS
font_family      family='Maple Mono NF CN' postscript_name=MapleMono-NF-CN-Medium
bold_font        auto
italic_font      auto
bold_italic_font auto
font_size 12.0
# END_KITTY_FONTS

tab_bar_edge top
tab_bar_style powerline
tab_powerline_style   slanted

# Animated cursor
cursor_trail 1

# change to x11 or wayland or leave auto
linux_display_server auto

scrollback_lines 2000
wheel_scroll_min_lines 1

enable_audio_bell no

window_padding_width 4

# include colors.conf


# BEGIN_KITTY_THEME
# Alabaster Dark
include VSCode_Dark.conf
# END_KITTY_THEME