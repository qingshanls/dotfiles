layout {

    focus-ring {
        active-color   "#b5c4ff"
        inactive-color "#131313"
        urgent-color   "#ffb4ab"
    }

    border {
        active-color   "#b5c4ff"
        inactive-color "#131313"
        urgent-color   "#ffb4ab"
    }

    shadow {
        color "#00000070"
    }

    tab-indicator {
        active-color   "#b5c4ff"
        inactive-color "#264190"
        urgent-color   "#ffb4ab"
    }

    insert-hint {
        color "#b5c4ff80"
    }
}

recent-windows {
    highlight {
        active-color "#b5c4ff"
        urgent-color "#ffb4ab"
    }
}
